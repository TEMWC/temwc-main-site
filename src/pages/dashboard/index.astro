---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Dashboard | ${SITE_TITLE}`} description="Your account dashboard for Trails End Mutual Water Company." />
	</head>
	<body>
		<Header />
		<main>
			<h2>Account Information</h2>
			<p>
				Welcome to the Trails End Mutual Water Companies web site.
				We are here to serve the community by providing clean fresh
				mountain water to our comunity.
			</p>			
		</main>
		<Footer />
	</body>
</html>
